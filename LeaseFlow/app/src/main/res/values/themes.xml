<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema base de LeaseFlow -->
    <style name="Theme.LeaseFlow" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">@color/lf_purple</item>
        <item name="android:colorPrimaryDark">@color/lf_navy</item>
        <item name="android:colorAccent">@color/lf_purple_2</item>

        <item name="android:windowBackground">@color/lf_bg</item>

        <item name="android:statusBarColor">@color/lf_navy</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Tema para Material3 (usado por Jetpack Compose) -->
    <style name="Theme.leaseflow" parent="Theme.LeaseFlow" />

    <style name="theme.UINavegacion.Splash" parent="Theme.SplashScreen">

        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.LeaseFlow</item>

    </style>


</resources>
